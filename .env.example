# Copy to .env and fill in. .env is gitignored.

# LiteLLM routes "groq/..." model IDs with this key.
GROQ_API_KEY=gsk_...

# Optional: swap providers by changing LLM_MODEL (any LiteLLM-supported ID works).
# Examples: groq/llama-3.3-70b-versatile | xai/grok-2-latest | deepseek/deepseek-chat
LLM_MODEL=groq/llama-3.3-70b-versatile

# Telegram bot: create via @BotFather, then message your bot once and grab chat_id
# from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=123456789

# Scoring threshold — only jobs >= this score get a Telegram ping.
SCORE_THRESHOLD=7

# Path to your CV (markdown). Gitignored.
CV_PATH=cv.md

# SQLite database path
DB_PATH=jobs.db
